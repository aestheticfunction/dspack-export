{
  "color": {
    "$type": "color",
    "primary": {
      "$value": "#2563eb",
      "$description": "Primary brand color (authoritative value from the design token file)."
    },
    "accent": {
      "$value": "#f59e0b"
    },
    "brand-alias": {
      "$value": "{color.primary}"
    }
  },
  "spacing": {
    "$type": "dimension",
    "sm": { "$value": "8px" },
    "md": { "$value": { "value": 16, "unit": "px" } }
  },
  "font": {
    "sans": {
      "$type": "fontFamily",
      "$value": ["Inter", "system-ui", "sans-serif"]
    },
    "weight-bold": {
      "$type": "fontWeight",
      "$value": 700
    }
  },
  "effect": {
    "shadow-sm": {
      "$type": "shadow",
      "$value": { "color": "#0000001a", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" }
    }
  }
}
